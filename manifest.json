{
  "manifest_version": 3,
  "name": "EcoLens",
  "version": "2.0",
  "description": "Real-time CO2 tracking for supported searches, queries, and streams with grid-aware estimates.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.netflix.com/watch*",
        "https://www.youtube.com/watch*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "webRequest",
    "notifications"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://www.gstatic.com/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://*.oaistatic.com/*",
    "https://*.oaiusercontent.com/*",
    "https://claude.ai/*",
    "https://*.anthropic.com/*",
    "https://gemini.google.com/*",
    "https://*.googleapis.com/*",
    "https://www.netflix.com/*",
    "https://*.netflix.com/*",
    "https://*.nflximg.net/*",
    "https://*.nflxvideo.net/*",
    "https://www.youtube.com/*",
    "https://*.googlevideo.com/*",
    "https://*.ytimg.com/*",
    "https://i.ytimg.com/*",
    "https://api.electricitymap.org/*",
    "https://ipapi.co/*",
    "https://*.supabase.co/*"
  ],
  "icons": {
    "128": "icon.png"
  }
}
